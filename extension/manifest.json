{
  "manifest_version": 3,
  "name": "BlackBird",
  "version": "1.0.0",
  "description": "Customize your school portal with custom backgrounds and GIFs",
  "permissions": ["activeTab", "storage", "scripting", "unlimitedStorage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}