{
  "manifest_version": 3,
  "name": "BlackBoard Editor 3000 by Eugene",
  "version": "1.1.0",
  "description": "Customize Mapúa Blackboard with custom backgrounds, colors, and more",
  "permissions": ["activeTab", "storage", "scripting", "unlimitedStorage", "sidePanel", "tabs"],
  "host_permissions": ["*://mapua.blackboard.com/*"],
  "action": {
    "default_title": "Open BlackBoard Editor 3000"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://mapua.blackboard.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}